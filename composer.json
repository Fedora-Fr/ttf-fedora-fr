{
    "name": "fedora-fr/ttf-borsalinux-fr",
    "description": "WordPress Twenty Twenty Five child theme.",
    "authors": [
        {
            "name": "Guillaume Kulakowski",
            "email": "guillaume@kulakowski.fr"
        }
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0"
    },
    "scripts": {
        "test": [
            "@phpcs"
        ],
        "test:all": [
            "@phpcs",
            "@npm:eslint",
            "@npm:stylelint"
        ],
        "phpcs": [
            "vendor/bin/phpcs -p -s"
        ],
        "npm:eslint": [
            "npm run eslint"
        ],
        "npm:stylelint": [
            "npm run stylelint"
        ],
        "phpcs:fix": [
            "vendor/bin/phpcbf -p -s"
        ]
    }
}
