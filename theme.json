{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#ffffff",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#000000",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#294172",
					"name": "Dark Fedora blue",
					"slug": "accent-1"
				},
				{
					"color": "color-mix(in srgb, #294172 75%, transparent)",
					"name": "Dark Fedora blue (75%)",
					"slug": "accent-1-percent-75"
				},
				{
					"color": "color-mix(in srgb, #294172 50%, transparent)",
					"name": "Dark Fedora blue (50%)",
					"slug": "accent-1-percent-50"
				},
				{
					"color": "color-mix(in srgb, #294172 10%, transparent)",
					"name": "Dark Fedora blue (10%)",
					"slug": "accent-1-percent-10"
				},
				{
					"color": "#3c6eb4",
					"name": "Fedora blue",
					"slug": "accent-2"
				},
				{
					"color": "color-mix(in srgb, #3c6eb4 75%, transparent)",
					"name": "Fedora blue (75%)",
					"slug": "accent-2-percent-75"
				},
				{
					"color": "color-mix(in srgb, #3c6eb4 50%, transparent)",
					"name": "Fedora blue (50%)",
					"slug": "accent-2-percent-50"
				},
				{
					"color": "color-mix(in srgb, #3c6eb4 10%, transparent)",
					"name": "Fedora blue (10%)",
					"slug": "accent-2-percent-10"
				},
				{
					"color": "#51a2da",
					"name": "New Fedora blue",
					"slug": "accent-3"
				},
				{
					"color": "color-mix(in srgb, #51a2da 75%, transparent)",
					"name": "New Fedora blue (75%)",
					"slug": "accent-3-percent-75"
				},
				{
					"color": "color-mix(in srgb, #51a2da 50%, transparent)",
					"name": "New Fedora blue (50%)",
					"slug": "accent-3-percent-50"
				},
				{
					"color": "color-mix(in srgb, #51a2da 10%, transparent)",
					"name": "New Fedora blue (10%)",
					"slug": "accent-3-percent-10"
				},
				{
					"color": "#a07cbc",
					"name": "Freedom Purple",
					"slug": "accent-4"
				},
				{
					"color": "color-mix(in srgb, #a07cbc 75%, transparent)",
					"name": "Freedom Purple (75%)",
					"slug": "accent-4-percent-75"
				},
				{
					"color": "color-mix(in srgb, #a07cbc 50%, transparent)",
					"name": "Freedom Purple (50%)",
					"slug": "accent-4-percent-50"
				},
				{
					"color": "color-mix(in srgb, #a07cbc 10%, transparent)",
					"name": "Freedom Purple (10%)",
					"slug": "accent-4-percent-10"
				},
				{
					"color": "#db3279",
					"name": "Friends Magenta",
					"slug": "accent-5"
				},
				{
					"color": "color-mix(in srgb, #db3279 75%, transparent)",
					"name": "Friends Magenta (75%)",
					"slug": "accent-5-percent-75"
				},
				{
					"color": "color-mix(in srgb, #db3279 50%, transparent)",
					"name": "Friends Magenta (50%)",
					"slug": "accent-5-percent-50"
				},
				{
					"color": "color-mix(in srgb, #db3279 10%, transparent)",
					"name": "Friends Magenta (10%)",
					"slug": "accent-5-percent-10"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Accent 6",
					"slug": "accent-6"
				},
				{
					"color": "#e59728",
					"name": "Features Orange",
					"slug": "accent-7"
				},
				{
					"color": "color-mix(in srgb, #e59728 75%, transparent)",
					"name": "Features Orange (75%)",
					"slug": "accent-7-percent-75"
				},
				{
					"color": "color-mix(in srgb, #e59728 50%, transparent)",
					"name": "Features Orange (50%)",
					"slug": "accent-7-percent-50"
				},
				{
					"color": "color-mix(in srgb, #e59728 10%, transparent)",
					"name": "Features Orange (10%)",
					"slug": "accent-7-percent-10"
				},
				{
					"color": "#79db32",
					"name": "First Green",
					"slug": "accent-8"
				},
				{
					"color": "color-mix(in srgb, #79db32 75%, transparent)",
					"name": "First Green (75%)",
					"slug": "accent-8-percent-75"
				},
				{
					"color": "color-mix(in srgb, #79db32 50%, transparent)",
					"name": "First Green (50%)",
					"slug": "accent-8-percent-50"
				},
				{
					"color": "color-mix(in srgb, #79db32 10%, transparent)",
					"name": "First Green (10%)",
					"slug": "accent-8-percent-10"
				},
				{
					"color": "#e5e7eb",
					"name": "Grey",
					"slug": "accent-9"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "Open sans",
					"slug": "open-sans",
					"fontFamily": "\"Open Sans\", sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/dist/open-sans-latin-ext-wght-normal.woff2"
							],
							"fontWeight": "300 800",
							"fontStyle": "normal",
							"fontFamily": "\"Open Sans\""
						}
					]
				},
				{
					"name": "Montserrat",
					"slug": "montserrat",
					"fontFamily": "Montserrat, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/dist/montserrat-latin-wght-normal.woff2"
							],
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"fontFamily": "Montserrat"
						}
					]
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|open-sans",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "300",
			"letterSpacing": "-0.1px",
			"lineHeight": "1.4"
		},
		"blocks": {
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "none"
							}
						},
						"typography": {
							"textDecoration": "none",
							"fontFamily": "var:preset|font-family|montserrat"
						}
					}
				}
			},
			"core/site-title": {
				"color": {
					"text": "var:preset|color|base"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "700",
					"letterSpacing": "-.5px"
				},
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "none"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"letterSpacing": "0.5px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700",
					"letterSpacing": "1.4px",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"color": {
					"text": "var:preset|color|accent-2"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat",
					"fontWeight": "400",
					"lineHeight": "1.125",
					"letterSpacing": "-0.1px"
				}
			}
		}
	}
}
